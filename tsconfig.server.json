{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": false,
    "outDir": "./dist/server",
    "rootDir": ".",
    "verbatimModuleSyntax": true
  },
  "include": ["server/**/*.ts", "shared/**/*.ts"]
}
